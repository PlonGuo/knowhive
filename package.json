{
  "name": "knowhive",
  "type": "module",
  "version": "0.1.0",
  "description": "Local-first AI knowledge base desktop app",
  "main": "out/main/index.js",
  "author": "PlonGuo",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:all": "concurrently -k -n vite,backend,electron \"vite\" \"cd backend && uv run uvicorn app.main:app --reload --port 8000\" \"wait-on tcp:5173 && electron .\"",
    "build": "tsc --noEmit && electron-vite build",
    "build:dry": "electron-builder --config electron-builder.yml --dir --publish never",
    "preview": "electron-vite preview",
    "lint": "eslint src electron --ext .ts,.tsx",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["electron", "esbuild"]
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "eslint": "^8.57.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.2",
    "vite": "^5.3.1",
    "wait-on": "^7.2.0"
  }
}
